<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sistema Asistencia Eventos ST</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/estilos.css">
  </head>
  <body class="demo-home">
    <div class="login-grid">
      <section class="login-preview soft-shadow">
        <div>
          <div class="hero-brand mb-4">
            <div class="brand-mark">ST</div>
            <div>
              <span class="demo-kicker">Sistema Asistencia Eventos</span>
              <h1 class="mt-3">Control de acceso y asistencia</h1>
              <p class="mt-3 mb-0">Accede con tu correo y contrasena. La plataforma gestiona roles, eventos, unidades, personas e ingresos.</p>
            </div>
          </div>
          <div class="hero-grid mt-4">
            <div class="hero-metric">
              <span>Roles</span>
              <strong>Administrador, Encargado, Guardia</strong>
            </div>
            <div class="hero-metric">
              <span>Personas</span>
              <strong>Registro centralizado</strong>
            </div>
            <div class="hero-metric">
              <span>Eventos</span>
              <strong>Gestion simple</strong>
            </div>
            <div class="hero-metric">
              <span>Informes</span>
              <strong>Proximamente</strong>
            </div>
          </div>
        </div>

        <div class="mt-4">
          <div class="demo-small text-white-50 mb-2">Accesos disponibles</div>
          <div class="role-list">
            <div class="role-card"><span>Administrador</span><small>Gestion completa</small></div>
            <div class="role-card"><span>Encargado</span><small>Registro de personas</small></div>
            <div class="role-card"><span>Guardia</span><small>Control de ingreso</small></div>
          </div>
        </div>
      </section>

      <section class="login-panel soft-shadow">
        <div class="login-card">
          <div class="brand-box mb-3">
            <div class="brand-mark small">ST</div>
            <div>
              <div class="fw-bold">Ingreso seguro</div>
              <div class="demo-small">Solo correo y contrasena.</div>
            </div>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form action="/login" method="post" class="row g-3">
            <div class="col-12">
              <label class="form-label">Correo</label>
              <input name="correo" type="email" class="form-control" required>
            </div>
            <div class="col-12">
              <label class="form-label">Contrasena</label>
              <input name="clave" type="password" class="form-control" required>
            </div>
            <div class="col-12">
              <button class="btn btn-brand w-100" type="submit">Ingresar</button>
            </div>
          </form>
        </div>
      </section>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>
</html>
