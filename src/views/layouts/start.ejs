<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sistema Asistencia Eventos ST</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/estilos.css">
  </head>
  <body class="<%= typeof bodyClass !== 'undefined' && bodyClass ? bodyClass : 'demo-app' %>">
    <% if (showShell) { %>
      <div class="app-shell">
        <aside class="sidebar">
          <div class="brand-box mb-4">
            <div class="brand-mark small">ST</div>
            <div>
              <strong>Sistema ST</strong>
              <small class="d-block muted">Control de acceso</small>
            </div>
          </div>

          <nav class="nav flex-column mb-4">
            <% (navItems || []).forEach((item) => { %>
              <a class="nav-link <%= item.active ? 'active' : '' %>" href="<%= item.href %>"><%= item.label %></a>
            <% }) %>
          </nav>

          <div class="sidebar-footer">
            <div class="mb-3">
              <div class="fw-bold"><%= user?.nombre || 'Invitado' %></div>
              <small class="text-white-50"><%= user?.unidad_nombre || user?.rol || 'Sin unidad' %></small>
            </div>
            <a class="btn btn-outline-light w-100" href="/logout">Salir</a>
          </div>
        </aside>

        <main class="app-main">
          <header class="app-topbar">
            <div>
              <span class="eyebrow"><%= pageRole || 'Sistema' %></span>
              <h1 class="page-title"><%= title %></h1>
              <% if (subtitle) { %>
                <p class="page-subtitle"><%= subtitle %></p>
              <% } %>
            </div>
            <div class="app-user">
              <div>
                <strong><%= user?.nombre || 'Invitado' %></strong>
                <small><%= user?.unidad_nombre || user?.rol || 'Acceso' %></small>
              </div>
            </div>
          </header>
    <% } %>
